{
  "name": "voice-meet",
  "version": "0.2.28",
  "description": "P2P 语音会议系统（Electron + WebRTC + 阿里云 fun-asr-realtime）",
  "license": "AGPL-3.0-or-later",
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:renderer\" \"npm:dev:electron\"",
    "dev:renderer": "vite",
    "dev:electron": "wait-on tcp:5173 && tsc -p tsconfig.main.json && electron .",
    "build": "tsc -p tsconfig.main.json && vite build",
    "start": "electron .",
    "typecheck": "tsc -p tsconfig.main.json --noEmit && tsc -p tsconfig.renderer.json --noEmit",
    "icons": "node build/generate-icons.mjs",
    "package": "npm run icons && npm run build && electron-builder"
  },
  "dependencies": {
    "dotenv": "^17.4.2",
    "simple-peer": "^9.11.1",
    "uuid": "^10.0.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/simple-peer": "^9.11.8",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.5.10",
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^8.2.2",
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3",
    "png-to-ico": "^3.0.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sharp": "^0.34.5",
    "typescript": "^5.5.0",
    "vite": "^5.3.0",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.catchat.app",
    "productName": "CatChat",
    "directories": {
      "output": "release"
    },
    "protocols": [
      {
        "name": "CatChat",
        "schemes": [
          "aimeet"
        ]
      }
    ],
    "files": [
      "dist/**/*",
      "build/icon.png",
      "node_modules/**/*",
      "!**/.env",
      "!**/.env.*",
      "!**/*.map",
      "!**/test/**",
      "!**/tests/**",
      "!**/*.md",
      "!**/.bin/**",
      "!**/{CHANGELOG.md,LICENSE,license,README.md,readme.md,HISTORY.md}"
    ],
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    },
    "mac": {
      "target": "dmg",
      "icon": "build/icon.png"
    },
    "linux": {
      "target": "AppImage",
      "icon": "build/icon.png"
    },
    "nsis": {
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "installerHeaderIcon": "build/icon.ico"
    }
  }
}
